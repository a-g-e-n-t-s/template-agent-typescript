{
  "name": "template-agent-typescript",
  "version": "1.0.0",
  "description": "This is a template agent built with typescript.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest"
  },
  "keywords": [
    "kadi",
    "agent",
    "template",
    "multi-agent",
    "typescript"
  ],
  "author": "Yu-Wei Tseng",
  "license": "Apache-2.0",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.106.0",
    "@kadi.build/core": "latest",
    "agents-library": "latest",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@vitest/coverage-v8": "^3.1.0",
    "eslint": "^9.19.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.24.0",
    "vitest": "^3.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}